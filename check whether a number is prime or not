#include<stdio.h>
int main()
{
   int n,i=2,f=0;
   printf("Enter a positive number");
   scanf("%d",&n);
   while(i<n)
   {
      if(n%i==0)
      {
         f++;
         break;
      }
      else
         i++;
   }
   if(f==0)
      printf("\nPrime number");
   else
      printf("\nNot a prime number");
   return 0;
}
